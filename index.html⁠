<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>SHERIFF LUCAS</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Black+Ops+One&family=Rajdhani:wght@600;700&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { width: 100%; height: 100%; overflow: hidden; background: #050505; }

  /* ═══ SCENE ═══════════════════════════════════════════ */
  #scene {
    position: fixed; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
  }

  /* ═══ FULL-SCREEN FLASH PANELS ════════════════════════ */
  #left-flash, #right-flash {
    position: fixed; top: 0; bottom: 0; width: 50%;
    pointer-events: none; opacity: 0;
  }
  #left-flash  { left: 0;
    background: radial-gradient(ellipse at 15% 50%, #ff2020 0%, #990000 55%, #330000 100%); }
  #right-flash { right: 0;
    background: radial-gradient(ellipse at 85% 50%, #2255ff 0%, #001aaa 55%, #000533 100%); }
  #left-flash.lit  { opacity: 1; }
  #right-flash.lit { opacity: 1; }

  /* Strobe double-flash effect via JS class cycling */
  #left-flash.strobe, #right-flash.strobe { opacity: 0.55; }

  /* ═══ AMBIENT HALO (always visible, subtle) ═══════════ */
  #halo-left, #halo-right {
    position: fixed; top: 0; bottom: 0; width: 38%;
    pointer-events: none; opacity: 0;
    transition: opacity 0.6s;
    z-index: 1;
  }
  #halo-left  { left: 0;  background: radial-gradient(ellipse at 0% 50%, rgba(255,20,20,0.18) 0%, transparent 70%); }
  #halo-right { right: 0; background: radial-gradient(ellipse at 100% 50%, rgba(20,80,255,0.18) 0%, transparent 70%); }
  .lights-active #halo-left, .lights-active #halo-right { opacity: 1; }

  /* ═══ VIGNETTE ════════════════════════════════════════ */
  #vignette {
    position: fixed; inset: 0;
    background: radial-gradient(ellipse at center, transparent 28%, rgba(0,0,0,0.88) 100%);
    pointer-events: none; z-index: 6;
  }

  /* ═══ SCAN LINES ══════════════════════════════════════ */
  #scanlines {
    position: fixed; inset: 0; pointer-events: none; z-index: 300;
    background: repeating-linear-gradient(
      0deg, transparent, transparent 2px,
      rgba(0,0,0,0.09) 2px, rgba(0,0,0,0.09) 3px
    );
  }

  /* ═══ LIGHT STREAK RAYS ═══════════════════════════════ */
  #rays {
    position: fixed; inset: 0; pointer-events: none; z-index: 2;
    opacity: 0; transition: opacity 0.4s;
  }
  .lights-active #rays { opacity: 1; }

  .ray {
    position: absolute;
    top: 50%; left: 50%;
    width: 120vmax; height: 2px;
    transform-origin: 0 50%;
    opacity: 0;
  }
  .ray.red-ray  { background: linear-gradient(90deg, rgba(255,30,30,0.0), rgba(255,30,30,0.18) 30%, transparent); }
  .ray.blue-ray { background: linear-gradient(90deg, rgba(30,80,255,0.0), rgba(30,80,255,0.18) 30%, transparent); }

  /* ═══ CORNER TEXT ════════════════════════════════════ */
  .corner {
    position: fixed;
    font-family: 'Rajdhani', sans-serif; font-weight: 600;
    font-size: 10px; letter-spacing: 0.32em;
    color: rgba(255,255,255,0.12);
    z-index: 20; user-select: none; text-transform: uppercase;
  }
  .corner.tl { top: 22px; left: 20px; }
  .corner.tr { top: 22px; right: 20px; text-align: right; }
  .corner.bl { bottom: 22px; left: 20px; }
  .corner.br { bottom: 22px; right: 22px; text-align: right; font-variant-numeric: tabular-nums; }

  /* ═══ NAMEPLATE ══════════════════════════════════════ */
  #nameplate {
    position: relative; z-index: 10;
    text-align: center; margin-bottom: 16px;
    user-select: none; line-height: 1;
  }
  .title-sheriff {
    font-family: 'Rajdhani', sans-serif; font-weight: 600;
    font-size: clamp(11px, 2.2vw, 15px);
    letter-spacing: 0.7em; color: rgba(255,255,255,0.28);
    text-transform: uppercase; display: block; margin-bottom: 5px;
  }
  /* ── LUCAS name wrapper for layered effects ── */
  .lucas-wrap {
    position: relative;
    display: inline-block;
    margin: 2px 0 0;
  }

  .title-lucas {
    font-family: 'Black Ops One', sans-serif;
    font-size: clamp(62px, 16vw, 104px);
    letter-spacing: 0.15em;
    color: #e8e2d4;
    text-shadow:
      0 4px 0 rgba(0,0,0,0.95),
      0 0 40px rgba(220,200,140,0.1);
    display: block;
    position: relative;
    z-index: 2;
  }

  /* Chrome effect: two pseudo ghost layers */
  .title-lucas::before,
  .title-lucas::after {
    content: 'LUCAS';
    position: absolute;
    top: 0; left: 0; right: 0;
    font-family: 'Black Ops One', sans-serif;
    font-size: inherit;
    letter-spacing: inherit;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .title-lucas::before {
    color: #ff3a3a;
    clip-path: polygon(0 0, 100% 0, 100% 45%, 0 45%);
    transform: translateX(-3px);
    mix-blend-mode: screen;
  }
  .title-lucas::after {
    color: #3a6fff;
    clip-path: polygon(0 55%, 100% 55%, 100% 100%, 0 100%);
    transform: translateX(3px);
    mix-blend-mode: screen;
  }

  /* Idle: subtle shimmer only */
  .title-lucas {
    animation: shimmer-idle 4s infinite;
  }
  @keyframes shimmer-idle {
    0%,90%,100% { text-shadow: 0 4px 0 rgba(0,0,0,0.95), 0 0 40px rgba(220,200,140,0.08); }
    95% { text-shadow: 0 4px 0 rgba(0,0,0,0.95), 0 0 60px rgba(220,200,140,0.35), 0 0 100px rgba(200,180,100,0.15); }
  }

  /* Active: amber pulse + glitch */
  #nameplate.active .title-lucas {
    animation: amber-pulse 0.52s infinite alternate, glitch 2.5s infinite;
  }
  #nameplate.active .title-lucas::before,
  #nameplate.active .title-lucas::after { opacity: 1; }
  #nameplate.active .title-lucas::before { animation: glitch-red  2.5s infinite; }
  #nameplate.active .title-lucas::after  { animation: glitch-blue 2.5s infinite; }

  @keyframes amber-pulse {
    0%   { color: #ffd580; text-shadow: 0 4px 0 rgba(0,0,0,0.95), 0 0 50px rgba(255,180,40,0.6), 0 0 100px rgba(255,140,0,0.3); }
    100% { color: #fff0c0; text-shadow: 0 4px 0 rgba(0,0,0,0.95), 0 0 80px rgba(255,215,80,0.8), 0 0 140px rgba(255,170,0,0.45); }
  }

  @keyframes glitch {
    0%,94%,100% { transform: translate(0); filter: none; }
    95%  { transform: translate(-4px, 1px) skewX(-2deg); filter: hue-rotate(30deg); }
    96%  { transform: translate(4px, -1px) skewX(2deg);  filter: hue-rotate(-20deg); }
    97%  { transform: translate(0); filter: none; }
    98%  { transform: translate(-2px, 2px); filter: brightness(1.6); }
    99%  { transform: translate(2px, -2px); filter: none; }
  }
  @keyframes glitch-red {
    0%,94%,100% { transform: translateX(-3px); opacity: 1; }
    95%  { transform: translateX(-12px) skewX(-4deg); opacity: 0.9; }
    96%  { transform: translateX(6px);  opacity: 0.4; }
    97%  { transform: translateX(-3px); opacity: 1; }
  }
  @keyframes glitch-blue {
    0%,94%,100% { transform: translateX(3px); opacity: 1; }
    95%  { transform: translateX(12px)  skewX(4deg);  opacity: 0.9; }
    96%  { transform: translateX(-6px); opacity: 0.4; }
    97%  { transform: translateX(3px);  opacity: 1; }
  }

  .title-sub {
    font-family: 'Rajdhani', sans-serif; font-weight: 600;
    font-size: clamp(9px, 1.7vw, 12px);
    letter-spacing: 0.52em; color: rgba(255,255,255,0.13);
    margin-top: 9px; display: block; text-transform: uppercase;
  }

  /* ═══ BADGE ══════════════════════════════════════════ */
  #badge {
    position: relative; z-index: 10;
    margin-bottom: 28px; user-select: none; text-align: center;
  }
  .badge-star {
    font-size: clamp(34px, 7.5vw, 50px); line-height: 1; display: block;
    filter: drop-shadow(0 0 10px rgba(255,220,90,0.22));
    transition: filter 0.3s;
  }
  #nameplate.active ~ #badge .badge-star {
    filter: drop-shadow(0 0 20px rgba(255,200,60,0.6)) drop-shadow(0 0 40px rgba(255,150,0,0.3));
    animation: star-spin 8s linear infinite;
  }
  @keyframes star-spin {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* ═══ BUTTON ═════════════════════════════════════════ */
  #btn-wrap { position: relative; z-index: 10; }

  /* Outer glow ring */
  #btn-ring {
    position: absolute;
    inset: -18px;
    border-radius: 50%;
    background: transparent;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
  }
  #btn-ring.active { opacity: 1; animation: ring-pulse 0.52s infinite alternate; }
  @keyframes ring-pulse {
    0%   { box-shadow: 0 0 0 4px rgba(255,80,80,0.25),  0 0 50px 8px rgba(255,40,40,0.2),  0 0 100px 20px rgba(255,0,0,0.08); }
    100% { box-shadow: 0 0 0 4px rgba(60,120,255,0.25), 0 0 50px 8px rgba(40,80,255,0.2), 0 0 100px 20px rgba(0,50,255,0.08); }
  }

  #activate-btn {
    width: clamp(150px, 34vw, 206px);
    height: clamp(150px, 34vw, 206px);
    border-radius: 50%; border: none; cursor: pointer; outline: none;
    background:
      radial-gradient(circle at 38% 30%, #2c2c2c 0%, #141414 50%, #080808 100%);
    box-shadow:
      0 0 0 3px #1a1a1a,
      0 0 0 7px #202020,
      0 0 0 9px #131313,
      0 14px 55px rgba(0,0,0,0.98),
      inset 0 1px 0 rgba(255,255,255,0.08),
      inset 0 -3px 12px rgba(0,0,0,0.8);
    transition: transform 0.11s cubic-bezier(0.34,1.5,0.64,1), box-shadow 0.15s;
    -webkit-tap-highlight-color: transparent;
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  #activate-btn:active { transform: scale(0.88); }

  /* Inner shine */
  #activate-btn::before {
    content: '';
    position: absolute;
    top: 8%; left: 15%; width: 40%; height: 28%;
    background: radial-gradient(ellipse, rgba(255,255,255,0.09), transparent);
    border-radius: 50%;
    pointer-events: none;
  }

  .btn-label {
    font-family: 'Black Ops One', sans-serif;
    font-size: clamp(16px, 3.6vw, 22px);
    letter-spacing: 0.06em; color: #383838;
    transition: color 0.25s, text-shadow 0.25s;
    pointer-events: none; position: relative; z-index: 1;
  }
  #activate-btn.active .btn-label {
    color: #fff8e0;
    text-shadow: 0 0 14px rgba(255,220,100,0.9), 0 0 28px rgba(255,180,50,0.5);
  }

  /* ═══ STATUS ═════════════════════════════════════════ */
  #status-text {
    position: relative; z-index: 10; margin-top: 30px;
    font-family: 'Rajdhani', sans-serif; font-weight: 600;
    font-size: clamp(10px, 1.9vw, 13px);
    letter-spacing: 0.6em; color: rgba(255,255,255,0.13);
    text-transform: uppercase; user-select: none; transition: color 0.3s;
  }
  #status-text.active {
    color: rgba(255,210,80,0.55);
    animation: status-blink 0.9s infinite;
  }
  @keyframes status-blink { 0%,100%{opacity:1} 50%{opacity:0.35} }

  /* ═══ PARTICLE SPARKS (canvas) ═══════════════════════ */
  #spark-canvas {
    position: fixed; inset: 0;
    pointer-events: none; z-index: 8;
    opacity: 0; transition: opacity 0.5s;
  }
  #spark-canvas.active { opacity: 1; }
</style>
</head>
<body>
<div id="scene">
  <div id="left-flash"></div>
  <div id="right-flash"></div>
  <div id="halo-left"></div>
  <div id="halo-right"></div>
  <div id="rays"></div>
  <div id="vignette"></div>
  <canvas id="spark-canvas"></canvas>
  <div id="scanlines"></div>

  <div class="corner tl">COUNTY SHERIFF</div>
  <div class="corner tr">DISPATCH ACTIVE</div>
  <div class="corner bl">CODE 3</div>
  <div class="corner br" id="clock">00:00:00</div>

  <div id="nameplate">
    <span class="title-sheriff">Sheriff</span>
    <span class="title-lucas">LUCAS</span>
    <span class="title-sub">警官专用 &nbsp;·&nbsp; Authorized Use Only</span>
  </div>

  <div id="badge"><span class="badge-star">⭐</span></div>

  <div id="btn-wrap">
    <div id="btn-ring"></div>
    <button id="activate-btn" onclick="toggleAll()">
      <span class="btn-label" id="btn-label">ACTIVATE</span>
    </button>
  </div>

  <div id="status-text">STANDBY</div>
</div>

<script>
// ══════════════════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════════════════
let active = false;
let flashInterval = null;
let phase = 0;

// ══════════════════════════════════════════════════════════
// AUDIO — Federal Signal PA300 "Yelp" mode
// Most common US police siren: fast up-down sweep ~0.25s/cycle
// ══════════════════════════════════════════════════════════
let audioCtx = null, sirenActive = false, nodes = {};

function getCtx() {
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  return audioCtx;
}

function makeCurve(k) {
  const n = 512, c = new Float32Array(n);
  for (let i = 0; i < n; i++) {
    const x = (i * 2) / n - 1;
    c[i] = ((Math.PI + k) * x) / (Math.PI + k * Math.abs(x));
  }
  return c;
}

function startSiren() {
  if (sirenActive) return;
  sirenActive = true;
  const ctx = getCtx();

  const master = ctx.createGain();
  master.gain.setValueAtTime(0, ctx.currentTime);
  master.gain.linearRampToValueAtTime(0.38, ctx.currentTime + 0.05);

  const comp = ctx.createDynamicsCompressor();
  comp.threshold.value = -10; comp.ratio.value = 10;
  comp.attack.value = 0.001; comp.release.value = 0.08;
  master.connect(comp); comp.connect(ctx.destination);

  // Primary yelp tone — sawtooth for that electric-motor rasp
  const osc = ctx.createOscillator();
  osc.type = 'sawtooth';

  const dist = ctx.createWaveShaper();
  dist.curve = makeCurve(60); dist.oversample = '4x';

  const gOsc = ctx.createGain(); gOsc.gain.value = 0.65;
  osc.connect(dist); dist.connect(gOsc); gOsc.connect(master);

  // Sub octave — adds real-world "chest thump"
  const sub = ctx.createOscillator();
  sub.type = 'sine';
  const gSub = ctx.createGain(); gSub.gain.value = 0.2;
  sub.connect(gSub); gSub.connect(master);

  // Third partial — bite/presence
  const harm = ctx.createOscillator();
  harm.type = 'triangle';
  const gHarm = ctx.createGain(); gHarm.gain.value = 0.08;
  harm.connect(gHarm); gHarm.connect(master);

  osc.start(); sub.start(); harm.start();
  nodes = { osc, sub, harm, master };

  // ── YELP: 580 Hz → 1260 Hz in 0.22s, drop back, repeat ──
  // This matches Federal Signal PA300 Yelp (most common US patrol car)
  function yelp() {
    if (!sirenActive) return;
    const now = ctx.currentTime;
    const LO = 580, HI = 1260, T = 0.22;

    osc.frequency.cancelScheduledValues(now);
    osc.frequency.setValueAtTime(LO, now);
    osc.frequency.exponentialRampToValueAtTime(HI, now + T);
    osc.frequency.exponentialRampToValueAtTime(LO, now + T * 2);

    sub.frequency.cancelScheduledValues(now);
    sub.frequency.setValueAtTime(LO / 2, now);
    sub.frequency.exponentialRampToValueAtTime(HI / 2, now + T);
    sub.frequency.exponentialRampToValueAtTime(LO / 2, now + T * 2);

    harm.frequency.cancelScheduledValues(now);
    harm.frequency.setValueAtTime(LO * 1.5, now);
    harm.frequency.exponentialRampToValueAtTime(HI * 1.5, now + T);
    harm.frequency.exponentialRampToValueAtTime(LO * 1.5, now + T * 2);

    setTimeout(yelp, T * 2 * 1000);
  }
  yelp();
}

function stopSiren() {
  sirenActive = false;
  if (!nodes.master) return;
  const ctx = getCtx();
  nodes.master.gain.setValueAtTime(nodes.master.gain.value, ctx.currentTime);
  nodes.master.gain.linearRampToValueAtTime(0, ctx.currentTime + 0.35);
  setTimeout(() => {
    try { nodes.osc.stop(); nodes.sub.stop(); nodes.harm.stop(); } catch(e){}
    nodes = {};
  }, 400);
}

// ══════════════════════════════════════════════════════════
// LIGHTS + STROBE
// ══════════════════════════════════════════════════════════
const leftEl  = document.getElementById('left-flash');
const rightEl = document.getElementById('right-flash');
const scene   = document.getElementById('scene');

// Authentic US light bar: double-flash per side, then switch
// Pattern: RR-BB-RR-BB (each flash ~65ms, gap 60ms, side switch 260ms)
let strobeStep = 0;
const STROBE_STEPS = [
  // [leftOn, rightOn, duration_ms]
  [true,  false, 65],
  [false, false, 55],
  [true,  false, 65],
  [false, false, 80],
  [false, true,  65],
  [false, false, 55],
  [false, true,  65],
  [false, false, 80],
];
let strobeTimer = null;

function runStrobe() {
  if (!active) return;
  const [l, r, dur] = STROBE_STEPS[strobeStep % STROBE_STEPS.length];
  l ? leftEl.classList.add('lit')  : leftEl.classList.remove('lit');
  r ? rightEl.classList.add('lit') : rightEl.classList.remove('lit');
  strobeStep++;
  strobeTimer = setTimeout(runStrobe, dur);
}

function startLights() {
  strobeStep = 0;
  scene.classList.add('lights-active');
  runStrobe();
  spawnRays();
}

function stopLights() {
  clearTimeout(strobeTimer);
  leftEl.classList.remove('lit');
  rightEl.classList.remove('lit');
  scene.classList.remove('lights-active');
  stopRays();
}

// ══════════════════════════════════════════════════════════
// LIGHT RAYS
// ══════════════════════════════════════════════════════════
const raysEl = document.getElementById('rays');
let rayAnimId = null;

function spawnRays() {
  raysEl.innerHTML = '';
  const angles = [15,35,55,75,95,115,135,155,195,215,235,255,275,295,315,335];
  angles.forEach((a, i) => {
    const ray = document.createElement('div');
    ray.className = 'ray ' + (i % 2 === 0 ? 'red-ray' : 'blue-ray');
    ray.style.transform = `rotate(${a}deg)`;
    ray.style.animation = `ray-sweep ${1.2 + (i % 3) * 0.4}s ${i * 0.07}s infinite alternate`;
    raysEl.appendChild(ray);
  });

  // Inject keyframes once
  if (!document.getElementById('ray-kf')) {
    const s = document.createElement('style');
    s.id = 'ray-kf';
    s.textContent = `
      @keyframes ray-sweep {
        0%   { opacity: 0; }
        40%  { opacity: 1; }
        100% { opacity: 0.1; }
      }
    `;
    document.head.appendChild(s);
  }
}

function stopRays() { raysEl.innerHTML = ''; }

// ══════════════════════════════════════════════════════════
// SPARK PARTICLES
// ══════════════════════════════════════════════════════════
const canvas = document.getElementById('spark-canvas');
const c2d = canvas.getContext('2d');
let sparks = [], sparkRaf = null, sparkRunning = false;

function resizeCanvas() {
  canvas.width  = window.innerWidth;
  canvas.height = window.innerHeight;
}
resizeCanvas();
window.addEventListener('resize', resizeCanvas);

function spawnSpark() {
  const side = Math.random() < 0.5 ? 'left' : 'right';
  const x = side === 'left'
    ? Math.random() * window.innerWidth * 0.45
    : window.innerWidth * 0.55 + Math.random() * window.innerWidth * 0.45;
  return {
    x, y: Math.random() * window.innerHeight,
    vx: (Math.random() - 0.5) * 3,
    vy: (Math.random() - 1.2) * 3,
    life: 1, decay: 0.012 + Math.random() * 0.02,
    size: 1 + Math.random() * 2.5,
    color: side === 'left'
      ? `rgba(255,${60+Math.random()*40|0},${20+Math.random()*20|0},`
      : `rgba(${40+Math.random()*30|0},${80+Math.random()*40|0},255,`,
  };
}

function drawSparks() {
  if (!sparkRunning) return;
  c2d.clearRect(0, 0, canvas.width, canvas.height);

  // Spawn new
  if (Math.random() < 0.55) sparks.push(spawnSpark());
  if (sparks.length > 120) sparks.splice(0, sparks.length - 120);

  sparks.forEach(s => {
    s.x += s.vx; s.y += s.vy;
    s.vy += 0.04; // gravity
    s.life -= s.decay;

    if (s.life <= 0) return;
    c2d.beginPath();
    c2d.arc(s.x, s.y, s.size * s.life, 0, Math.PI * 2);
    c2d.fillStyle = s.color + (s.life * 0.85) + ')';
    c2d.fill();

    // Tail
    c2d.beginPath();
    c2d.moveTo(s.x, s.y);
    c2d.lineTo(s.x - s.vx * 4, s.y - s.vy * 4);
    c2d.strokeStyle = s.color + (s.life * 0.4) + ')';
    c2d.lineWidth = s.size * s.life * 0.6;
    c2d.stroke();
  });

  sparks = sparks.filter(s => s.life > 0);
  sparkRaf = requestAnimationFrame(drawSparks);
}

function startSparks() {
  sparkRunning = true;
  canvas.classList.add('active');
  drawSparks();
}

function stopSparks() {
  sparkRunning = false;
  canvas.classList.remove('active');
  cancelAnimationFrame(sparkRaf);
  c2d.clearRect(0, 0, canvas.width, canvas.height);
  sparks = [];
}

// ══════════════════════════════════════════════════════════
// MAIN TOGGLE
// ══════════════════════════════════════════════════════════
const btn       = document.getElementById('activate-btn');
const btnRing   = document.getElementById('btn-ring');
const nameplate = document.getElementById('nameplate');

function toggleAll() {
  active = !active;
  const status = document.getElementById('status-text');
  const label  = document.getElementById('btn-label');

  if (active) {
    startLights();
    startSiren();
    startSparks();
    btn.classList.add('active');
    btnRing.classList.add('active');
    nameplate.classList.add('active');
    label.textContent = 'DEACTIVATE';
    status.textContent = '● RESPONDING';
    status.classList.add('active');
  } else {
    stopLights();
    stopSiren();
    stopSparks();
    btn.classList.remove('active');
    btnRing.classList.remove('active');
    nameplate.classList.remove('active');
    label.textContent = 'ACTIVATE';
    status.textContent = 'STANDBY';
    status.classList.remove('active');
  }
}

// ══════════════════════════════════════════════════════════
// CLOCK
// ══════════════════════════════════════════════════════════
function tick() {
  const d = new Date();
  document.getElementById('clock').textContent =
    [d.getHours(), d.getMinutes(), d.getSeconds()]
      .map(n => String(n).padStart(2,'0')).join(':');
}
tick(); setInterval(tick, 1000);
</script>
